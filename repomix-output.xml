      options: ['ライト', 'ダーク'],
      apply: (v) => onSetTheme(v === 'ライト' ? 'light' : 'dark'),
    },
    font: {
      title: 'フォントサイズ',
      current: settings.fontSize === 'small' ? '小' : settings.fontSize === 'large' ? '大' : '標準',
      options: ['小', '標準', '大'],
      apply: (v) => onSetFontSize(v === '小' ? 'small' : v === '大' ? 'large' : 'medium'),

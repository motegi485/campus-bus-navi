  return h * 60 + m
}

export function FullTimetable({ schedule, route, currentDeparture, nowMinutes }: Props) {
  const [open, setOpen] = useState(false)

  const isCampus = route === 'campus_to_station'
  const activeBg = isCampus ? '#d1fae5' : '#ede9fe'
